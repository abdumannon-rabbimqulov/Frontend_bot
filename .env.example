# Server Deployment Secrets (Example)
DEPLOY_PASSWORD="your_password_here"
DEPLOY_SERVER="root@your_server_ip"
DEPLOY_SSH_KEY="$HOME/.ssh/deploy_key"

# Logistika_bot API (host:port, no scheme) — nginx proxy_pass target
LOGISTIKA_BACKEND="158.220.100.58:8003"

# Production: logistic.org.uz API bilan bir serverda — ./deploy-logistic-vps.sh (SSH kalit 158 serverga)
# Alohida frontend VPS (138...) — oddiy deploy.sh + SITE_DOMAIN / nip.io
# HTTPS — A yozuv shu frontend VPS IP ga tushishi kerak (HTTP-01).
# Qo‘lda SITE_DOMAIN bo‘lmasa va DEPLOY_SERVER IP bo‘lsa, avtomatik YOUR_IP.nip.io ishlatiladi.
# logistic.org.uz hozir boshqa serverga ishora qilsa, certbot ishlamaydi — DNS ni tuzing yoki nip.io.
SITE_DOMAIN="logistic.org.uz"
CERTBOT_EMAIL="you@example.com"
