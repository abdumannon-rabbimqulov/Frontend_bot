# Standalone frontend repository deployment settings
# Backend API is expected on the same VPS at 127.0.0.1:8003.
LOGISTIKA_SSH_HOST="root@158.220.100.58"
LOGISTIKA_SSH_KEY="$HOME/.ssh/deploy_key"
LOGISTIKA_FRONTEND_REMOTE_DIR="/root/Frontend_bot"

# Domain and certificate settings for setup-ssl.sh
SITE_DOMAIN="logistic.org.uz"
CERTBOT_EMAIL="you@example.com"

# Set to 1 only if DNS is already being changed and you want to bypass the local DNS check.
FORCE_IGNORE_DNS=0

